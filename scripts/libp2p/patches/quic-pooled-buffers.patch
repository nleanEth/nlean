+    private void ObserveBackgroundTask(Task task, string operation)
+    {
+        task.ContinueWith(
+            t =>
+            {
+                if (t.Exception is AggregateException aggregate)
+                {
+                    foreach (var ex in aggregate.Flatten().InnerExceptions)
+                    {
+                        if (IsExpectedStreamShutdown(ex))
+                        {
+                            _logger?.LogDebug("Ignoring expected background QUIC shutdown in {Operation}: {Message}", operation, ex.Message);
+                        }
+                        else
+                        {
+                            _logger?.LogDebug("Background QUIC task faulted in {Operation}: {Message}", operation, ex.Message);
+                        }
+                    }
+                }
+            },
+            CancellationToken.None,
+            TaskContinuationOptions.OnlyOnFaulted | TaskContinuationOptions.ExecuteSynchronously,
+            TaskScheduler.Default);
+    }
+
+    private static bool IsExpectedStreamShutdown(Exception ex) =>
+        ex is OperationCanceledException
+        || ex is ObjectDisposedException
+        || ex is QuicException
+        || ex is SocketException
+        || ex is IOException;
