     private static readonly byte[] SignaturePrefix = "libp2p-tls-handshake:"u8.ToArray();
     private static byte[] ContentToSignFromTlsPublicKey(byte[] keyInfo) => [.. SignaturePrefix, .. keyInfo];
+
+    private static byte[] NormalizeSecp256k1SignatureToLowS(ReadOnlySpan<byte> derSignature, Core.Dto.KeyType keyType)
+    {
+        if (keyType != Core.Dto.KeyType.Secp256K1)
+        {
+            return derSignature.ToArray();
+        }
+
+        BigInteger n = BigInteger.Parse("00FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFEBAAEDCE6AF48A03BBFD25E8CD0364141",
+            System.Globalization.NumberStyles.HexNumber);
+        BigInteger halfN = n >> 1;
+
+        AsnReader reader = new(derSignature.ToArray(), AsnEncodingRules.DER);
+        AsnReader seq = reader.ReadSequence();
+        byte[] rBytes = seq.ReadIntegerBytes().ToArray();
+        byte[] sBytes = seq.ReadIntegerBytes().ToArray();
+
+        BigInteger s = new(sBytes, isUnsigned: false, isBigEndian: true);
+
+        if (s <= halfN)
+        {
+            return derSignature.ToArray();
+        }
+
+        BigInteger normalizedS = n - s;
+        BigInteger r = new(rBytes, isUnsigned: false, isBigEndian: true);
+
+        AsnWriter writer = new(AsnEncodingRules.DER);
+        writer.PushSequence();
+        writer.WriteInteger(r);
+        writer.WriteInteger(normalizedS);
+        writer.PopSequence();
+
+        return writer.Encode();
+    }
